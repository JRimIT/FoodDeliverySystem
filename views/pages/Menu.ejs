<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Menu - Foodie Express</title>

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/Menu.css" />
    <link rel="stylesheet" href="/css/navbar.css" />
  </head>

  <body class="bg-light">
    <!-- Navbar -->
    <%- include('../partials/navbar.ejs') %>

    <!-- Hero Section for Menu -->
    <section class="menu-hero position-relative d-flex align-items-center justify-content-center text-center mt-5">
        <div class="overlay position-absolute w-100 h-100"></div>
        <div class="container position-relative z-index-1 text-white py-5">
            <h1 class="display-4 fw-bold mb-3 font-outfit text-white">Explore Our Menu</h1>
            <p class="lead fw-light mx-auto" style="max-width: 600px;">
                Discover a wide variety of delicious meals, handpicked for you. From hearty mains to sweet treats.
            </p>
        </div>
    </section>

    <!-- Menu Section -->
    <div class="container menu-section my-5">
      
      <!-- Search & Filters Container -->
      <div class="bg-white p-4 rounded-4 shadow-sm mb-5" data-aos="fade-up">
        <div class="row align-items-center g-3">
          
          <!-- Search Form -->
          <div class="col-lg-5">
            <form
              class="d-flex w-100 position-relative"
              method="get"
              action="/Menu/listFoods"
            >
              <input type="hidden" name="category" value="<%= selectedCategory %>" />
              <i class="fas fa-search position-absolute text-muted" style="left: 15px; top: 50%; transform: translateY(-50%);"></i>
              <input
                type="text"
                class="form-control rounded-pill ps-5 py-2 border-0 bg-light"
                name="search"
                placeholder="Search for dishes..."
                value="<%= typeof search !== 'undefined' ? search : '' %>"
              />
              <button class="btn btn-danger rounded-pill px-4 ms-2 fw-bold shadow-sm" type="submit">
                Search
              </button>
            </form>
          </div>

          <!-- Filter Buttons -->
          <div class="col-lg-7 d-flex flex-wrap justify-content-lg-end justify-content-start gap-2">
            <a
              class="btn filter-pill <%= selectedCategory === 'All' ? 'active' : '' %>"
              href="/Menu/listFoods?page=1&category=All"
            >
              All
            </a>

            <% listCategory.forEach(category => { %>
            <a
              class="btn filter-pill <%= selectedCategory === category.category ? 'active' : '' %>"
              href="/Menu/listFoods?page=1&category=<%= category.category %>"
            >
              <%= category.category %>
            </a>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Product List -->
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="product-list">
        <% products.forEach(product=> { %>
        <div
          class="col product-item"
          data-category="<%= product.category %>"
          data-aos="fade-up"
        >
          <div class="card h-100 border-0 shadow-sm rounded-4 product-card overflow-hidden">
            <div class="position-relative">
              <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="w-100 object-fit-cover" style="height: 220px;" />
              <div class="price-badge position-absolute top-0 end-0 bg-danger text-white fw-bold px-3 py-2 rounded-start-pill mt-3 shadow-sm">
                  <%= product.price.toLocaleString('vi-VN') %>đ
              </div>
              <div class="category-badge position-absolute bottom-0 start-0 bg-white text-dark small fw-bold px-3 py-1 rounded-end-pill mb-3 ms-n1 shadow-sm">
                  <%= product.category %>
              </div>
            </div>
            <div class="card-body p-4 text-center d-flex flex-column">
              <h5 class="card-title fw-bold font-outfit mb-3 text-dark text-truncate"><%= product.name %></h5>
              <div class="mt-auto">
                <a
                  href="/detail/<%= product._id %>?category=<%= selectedCategory %>&page=<%= currentPage %>"
                  class="btn btn-outline-danger rounded-pill px-4 fw-bold w-100 btn-hover-scale"
                >
                  View Details <i class="fas fa-arrow-right ms-1"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
      <nav aria-label="Page navigation" class="mt-5">
        <ul class="pagination justify-content-center">
          <!-- Previous Button -->
          <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
            <a class="page-link shadow-sm rounded-pill px-3 me-2" href="/Menu/listFoods?page=<%= currentPage - 1 %>&category=<%= selectedCategory %>" aria-label="Previous">
              <span aria-hidden="true">&laquo; Prev</span>
            </a>
          </li>
          
          <!-- Page Numbers -->
          <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= currentPage === i ? 'active' : '' %>">
            <a
              class="page-link shadow-sm rounded-circle text-center mx-1"
              style="width: 40px; height: 40px; line-height: 24px;"
              href="/Menu/listFoods?page=<%= i %>&category=<%= selectedCategory %>"
              ><%= i %></a
            >
          </li>
          <% } %>

          <!-- Next Button -->
          <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
            <a class="page-link shadow-sm rounded-pill px-3 ms-2" href="/Menu/listFoods?page=<%= currentPage + 1 %>&category=<%= selectedCategory %>" aria-label="Next">
              <span aria-hidden="true">Next &raquo;</span>
            </a>
          </li>
        </ul>
      </nav>
      <% } %>
    </div>

    <%- include('../partials/footer.ejs') %>
