<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quick Order - Foodie Express</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">

    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/navbar.css" />
    <link rel="stylesheet" href="/css/Checkout.css" />
  </head>

  <body class="bg-light">
    <%- include('../partials/navbar.ejs') %>

    <!-- Quick Order Hero -->
    <section class="checkout-hero position-relative d-flex align-items-center justify-content-center text-center mt-5">
        <div class="overlay position-absolute w-100 h-100"></div>
        <div class="container position-relative z-index-1 text-white py-4">
            <h1 class="display-4 fw-bold mb-2 font-outfit text-white">Quick Order</h1>
            <p class="lead fw-light mx-auto" style="max-width: 600px;">
                You're just one step away from enjoying this delicious dish.
            </p>
        </div>
    </section>

    <div class="container my-5 pb-5">
      <div class="row" style="margin-top: -60px; position: relative; z-index: 10;">
        <div class="col-lg-10 mx-auto">
            <% if (typeof error !=='undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4 p-3 d-flex align-items-center" role="alert" data-aos="fade-down">
                <i class="fas fa-exclamation-circle me-3 fs-4"></i>
                <div>
                    <%= error %>
                    <a href="/wallet/deposit" class="btn btn-sm btn-danger ms-3 rounded-pill px-3 fw-bold">Deposit Now</a>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            <% } %>

            <form method="POST" action="/order/<%= product._id %>?quantity=<%= quantity %>">
                <div class="row g-4">
                    <!-- Left Column -->
                    <div class="col-lg-7" data-aos="fade-right">
                        <!-- Shipping Info -->
                        <div class="checkout-card p-4 p-md-5 shadow-sm mb-4">
                            <h4 class="fw-bold font-outfit mb-4 d-flex align-items-center text-dark">
                                <i class="fas fa-map-marker-alt text-danger me-2"></i> 1. Delivery Address
                            </h4>
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted text-uppercase">Shipping Address</label>
                                <div class="position-relative">
                                    <i class="fas fa-location-arrow position-absolute text-muted" style="left: 15px; top: 18px;"></i>
                                    <input type="text" class="form-control ps-5" name="address" placeholder="Enter your full delivery address..." required />
                                </div>
                            </div>
                            <div>
                                <label class="form-label small fw-bold text-muted text-uppercase">Note for Restaurant (Optional)</label>
                                <textarea class="form-control" name="note" rows="2" placeholder="Example: No onions, please."></textarea>
                            </div>
                        </div>

                        <!-- Payment Method -->
                        <div class="checkout-card p-4 p-md-5 shadow-sm">
                            <h4 class="fw-bold font-outfit mb-4 d-flex align-items-center text-dark">
                                <i class="fas fa-credit-card text-danger me-2"></i> 2. Payment Method
                            </h4>
                            <div class="payment-options">
                                <div class="form-check p-0 mb-3">
                                    <input class="form-check-input d-none" type="radio" name="paymentMethod" id="payWallet" value="wallet" checked />
                                    <label class="payment-option d-flex align-items-center" for="payWallet">
                                        <div class="icon-box me-3 fs-4 text-success"><i class="fas fa-wallet"></i></div>
                                        <div class="flex-grow-1">
                                            <h6 class="fw-bold mb-0">Internal Wallet</h6>
                                            <p class="text-muted small mb-0">Balance: <span class="fw-bold text-success"><%= user.balance?.toLocaleString('vi-VN') || 0 %>đ</span></p>
                                        </div>
                                        <i class="fas fa-check-circle check-icon text-success opacity-0"></i>
                                    </label>
                                </div>

                                <div class="form-check p-0 mb-3">
                                    <input class="form-check-input d-none" type="radio" name="paymentMethod" id="payCOD" value="cod" />
                                    <label class="payment-option d-flex align-items-center" for="payCOD">
                                        <div class="icon-box me-3 fs-4 text-warning"><i class="fas fa-truck-loading"></i></div>
                                        <div class="flex-grow-1">
                                            <h6 class="fw-bold mb-0">Cash on Delivery (COD)</h6>
                                            <p class="text-muted small mb-0">Pay when your food arrives.</p>
                                        </div>
                                        <i class="fas fa-check-circle check-icon text-success opacity-0"></i>
                                    </label>
                                </div>

                                <div class="form-check p-0">
                                    <input class="form-check-input d-none" type="radio" name="paymentMethod" id="payVNPay" value="vnpay" />
                                    <label class="payment-option d-flex align-items-center" for="payVNPay">
                                        <div class="icon-box me-3 fs-4 text-primary"><i class="fas fa-mobile-alt"></i></div>
                                        <div class="flex-grow-1">
                                            <h6 class="fw-bold mb-0">VNPay / Banking</h6>
                                            <p class="text-muted small mb-0">Pay securely via QR or Banking.</p>
                                        </div>
                                        <i class="fas fa-check-circle check-icon text-success opacity-0"></i>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="col-lg-5" data-aos="fade-left" data-aos-delay="100">
                        <div class="checkout-card p-4 p-md-5 shadow-sm sticky-top" style="top: 100px;">
                            <h4 class="fw-bold font-outfit mb-4 text-dark">Order Summary</h4>
                            
                            <div class="order-items-list mb-4">
                                <div class="d-flex align-items-center checkout-item">
                                    <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="product-thumb me-3 shadow-sm" />
                                    <div class="flex-grow-1">
                                        <h6 class="fw-bold mb-0 text-dark"><%= product.name %></h6>
                                        <span class="text-muted small">Qty: <%= quantity %></span>
                                    </div>
                                    <div class="text-end">
                                        <span class="fw-bold text-dark"><%= (product.price * quantity).toLocaleString('vi-VN') %>đ</span>
                                    </div>
                                </div>
                            </div>

                            <div class="total-highlight shadow-inner mb-4">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Subtotal</span>
                                    <span class="fw-bold"><%= (product.price * quantity).toLocaleString('vi-VN') %>đ</span>
                                </div>
                                <div class="border-top pt-3 d-flex justify-content-between align-items-center">
                                    <h5 class="fw-bold font-outfit mb-0">Total Amount</h5>
                                    <h4 class="fw-bold font-outfit mb-0 text-danger">
                                        <%= (product.price * quantity).toLocaleString('vi-VN') %>đ
                                    </h4>
                                </div>
                            </div>

                            <button type="submit" id="confirmBtn" class="btn btn-checkout-final w-100 shadow">
                                Confirm Order <i class="fas fa-bolt ms-2"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
      </div>
    </div>

    <!-- Payment Animation Overlay -->
    <div id="paymentOverlay" class="payment-overlay d-none">
        <div class="payment-modal text-center p-5 rounded-5 shadow-lg bg-white" data-aos="zoom-in">
            <div class="loader-wrapper mb-4">
                <div class="spinner-border text-danger" role="status" style="width: 3rem; height: 3rem;"></div>
            </div>
            <h4 class="fw-bold font-outfit mb-2">Processing Payment</h4>
            <p class="text-muted small mb-4">Securing your transaction...</p>
            
            <div class="deduction-box position-relative">
                <div class="current-balance fs-5 fw-bold text-dark mb-1">
                    <%= user.balance?.toLocaleString('vi-VN') || 0 %>đ
                </div>
                <div id="deductionAmount" class="deduction-text fw-bold text-danger">
                    - <%= (product.price * quantity).toLocaleString('vi-VN') %>đ
                </div>
            </div>
        </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const form = document.querySelector('form[action^="/order/"]');
        const overlay = document.getElementById('paymentOverlay');
        const deduction = document.getElementById('deductionAmount');

        if (!form) return;

        form.addEventListener('submit', function (e) {
          const paymentMethod = form.querySelector('input[name="paymentMethod"]:checked').value;
          
          if (paymentMethod === 'vnpay') {
            e.preventDefault();
            const newForm = form.cloneNode(true);
            newForm.target = '_blank';
            newForm.style.display = 'none';
            document.body.appendChild(newForm);
            Array.from(form.elements).forEach(el => {
              if (el.name && newForm.elements[el.name]) {
                newForm.elements[el.name].value = el.value;
              }
            });
            newForm.submit();
            document.body.removeChild(newForm);
            return;
          }

          if (paymentMethod === 'wallet') {
            e.preventDefault();
            overlay.classList.remove('d-none');
            overlay.classList.add('d-flex');
            setTimeout(() => { deduction.classList.add('animate-deduct'); }, 100);
            setTimeout(() => { form.submit(); }, 2000);
          }
        });
      });
    </script>
    <style>
        .payment-option { transition: all 0.3s ease; position: relative; }
        .form-check-input:checked + .payment-option {
            border-color: #ff6347 !important;
            background-color: #fff5f5 !important;
            box-shadow: 0 4px 12px rgba(255, 99, 71, 0.1);
        }
        .form-check-input:checked + .payment-option .check-icon { opacity: 1 !important; }
    </style>
    <%- include('../partials/footer.ejs') %>