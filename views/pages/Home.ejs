<%- include('../partials/header.ejs') %>

<div class="bodyHome pb-5">
  <!-- Navbar -->
  <%- include('../partials/navbar.ejs') %>

  <!-- Modern Hero Section -->
  <section class="home-hero position-relative d-flex align-items-center mt-5">
      <div class="overlay position-absolute w-100 h-100"></div>
      <div class="container position-relative z-index-1 text-white py-5">
          <div class="row align-items-center">
              <div class="col-lg-7 text-start" data-aos="fade-right" data-aos-duration="1000">
                  <span class="badge bg-warning text-dark mb-3 px-3 py-2 rounded-pill shadow-sm fw-bold">100% Fresh Ingredients</span>
                  <h1 class="display-3 fw-bold mb-4 font-outfit text-white">
                      Craving Something <span class="text-warning">Delicious?</span>
                  </h1>
                  <p class="lead mb-4 fw-light" style="max-width: 600px;">
                      We deliver the best food from your favorite local restaurants straight to your doorstep, piping hot and ready to enjoy.
                  </p>
                  <div class="d-flex gap-3">
                      <a href="/Menu/listFoods?page=1&category=All" class="btn btn-warning btn-lg rounded-pill fw-bold px-4 shadow-sm text-dark btn-hover-scale">
                          Order Now
                      </a>
                      <a href="/Menu/listFoods?page=1&category=All" class="btn btn-outline-light btn-lg rounded-pill fw-bold px-4 btn-hover-scale">
                          View Menu
                      </a>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <!-- How It Works Section -->
  <div class="container mt-5 pt-4">
      <div class="text-center mb-5" data-aos="fade-up">
          <h6 class="text-danger text-uppercase fw-bold letter-spacing-1 mb-2">Simple Process</h6>
          <h2 class="fw-bold font-outfit text-dark display-6">How It Works</h2>
      </div>
      
      <div class="row g-4 text-center px-lg-5">
          <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
              <div class="step-card p-4 rounded-4 bg-white shadow-sm h-100 border-0">
                  <div class="icon-wrapper mx-auto bg-danger text-white rounded-circle d-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 80px; height: 80px;">
                      <i class="fas fa-utensils fa-2x"></i>
                  </div>
                  <h4 class="fw-bold font-outfit mb-3">1. Choose Food</h4>
                  <p class="text-muted">Browse our extensive menu and choose your favorite meals from top-rated restaurants.</p>
              </div>
          </div>
          <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
              <div class="step-card p-4 rounded-4 bg-white shadow-sm h-100 border-0">
                  <div class="icon-wrapper mx-auto bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 80px; height: 80px;">
                      <i class="fas fa-credit-card fa-2x"></i>
                  </div>
                  <h4 class="fw-bold font-outfit mb-3">2. Easy Payment</h4>
                  <p class="text-muted">Pay quickly and securely with our multiple payment options including online banking.</p>
              </div>
          </div>
          <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
              <div class="step-card p-4 rounded-4 bg-white shadow-sm h-100 border-0">
                  <div class="icon-wrapper mx-auto bg-success text-white rounded-circle d-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 80px; height: 80px;">
                      <i class="fas fa-motorcycle fa-2x"></i>
                  </div>
                  <h4 class="fw-bold font-outfit mb-3">3. Fast Delivery</h4>
                  <p class="text-muted">Enjoy your meal hot and fresh as our riders deliver it directly to your doorstep in minutes.</p>
              </div>
          </div>
      </div>
  </div>

  <!-- Product Section -->
  <div class="container products-section mt-5" data-aos="fade-up">
    <div class="text-center mb-5">
        <h6 class="text-danger text-uppercase fw-bold letter-spacing-1 mb-2">Our Menu</h6>
        <h2 class="fw-bold font-outfit text-dark display-6">Popular Dishes</h2>
    </div>
    
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% listFeatureFood.forEach(food => {%>
      <div class="col" data-aos="zoom-in">
        <div class="card h-100 border-0 shadow-sm rounded-4 product-card overflow-hidden">
          <div class="position-relative">
            <img src="<%= food.imageUrl%>" alt="<%= food.name %>" class="w-100 object-fit-cover" style="height: 220px; transition: transform 0.5s ease;" />
            <div class="price-badge position-absolute top-0 end-0 bg-warning text-dark fw-bold px-3 py-2 rounded-start-pill mt-3 shadow-sm">
                <%= food.price.toLocaleString('vi-VN') %>đ
            </div>
          </div>
          <div class="card-body p-4 text-center">
            <h5 class="card-title fw-bold font-outfit mb-3 text-dark text-truncate"><%= food.name %></h5>
            
            <div class="d-flex justify-content-center align-items-center mt-4">
              <input
                type="number"
                min="1"
                value="1"
                class="form-control text-center me-3 border-danger rounded-pill fw-bold"
                style="width: 80px;"
                id="order-qty-<%= food._id %>"
              />
              <button
                class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center gap-2 btn-hover-scale w-100 justify-content-center"
                onclick="orderNow('<%= food._id %>')"
              >
                <i class="fas fa-shopping-cart"></i> Order Now
              </button>
            </div>
          </div>
        </div>
      </div>
      <%}) %>
    </div>
  </div>
</div>

<script>
  function orderNow(productId) {
    var qtyInput = document.getElementById("order-qty-" + productId);
    var quantity = qtyInput ? qtyInput.value : 1;
    window.location.href = `/order/${productId}?quantity=${quantity}`;
  }
</script>

<%- include('../partials/footer.ejs') %>
