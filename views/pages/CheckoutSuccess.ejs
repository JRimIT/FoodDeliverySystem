<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order Success - Foodie Express</title>
  
  <!-- Theme Management -->
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/js/theme-manager.js"></script>
  <script>
      (function() {
          const theme = localStorage.getItem('theme') || 'light';
          document.documentElement.setAttribute('data-theme', theme);
      })();
  </script>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  
  <!-- AOS Animation -->
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

  <link rel="stylesheet" href="/css/navbar.css" />
  
  <style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-body);
        color: var(--text-main);
    }
    .font-outfit {
        font-family: 'Outfit', sans-serif;
    }
    .success-card {
        max-width: 550px;
        background: var(--bg-card);
        color: var(--text-main);
        border-radius: 2.5rem;
        padding: 3.5rem 2rem;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-color);
        transition: transform 0.3s ease;
    }
    .success-card:hover {
        transform: translateY(-5px);
    }
    .icon-circle {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        font-size: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: 0 auto 2rem;
        box-shadow: 0 10px 20px rgba(40, 167, 69, 0.2);
    }
    .btn-continue {
        background: linear-gradient(90deg, #ff6347 0%, #fbc02d 100%);
        color: white;
        border: none;
        border-radius: 50px;
        padding: 1rem 2.5rem;
        font-weight: 700;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(255, 99, 71, 0.2);
        text-decoration: none;
        display: inline-block;
    }
    .btn-continue:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(255, 99, 71, 0.3);
        color: white;
    }
    .bg-pattern {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 400px;
        background: linear-gradient(135deg, rgba(255, 99, 71, 0.05) 0%, transparent 100%);
        z-index: -1;
    }
    .order-info-box {
        background-color: var(--bg-body);
        border: 1px solid var(--border-color);
    }
  </style>
</head>
<body class="d-flex flex-column min-vh-100">
  <%- include('../partials/navbar.ejs') %>

  <main class="flex-grow-1 position-relative d-flex align-items-center justify-content-center py-5 mt-5">
    <div class="bg-pattern"></div>
    
    <div class="container">
        <div class="success-card mx-auto text-center" data-aos="zoom-in">
            <div class="icon-circle mb-4 animate__animated animate__bounceIn">
                <i class="fas fa-check"></i>
            </div>
            
            <h2 class="display-6 fw-bold font-outfit mb-3" style="color: var(--text-main);">Order Placed Successfully!</h2>
            <p class="fs-5 mb-4 px-lg-4" style="color: var(--text-muted);">
                Thank you <strong><%= user?.username || 'Customer' %></strong> for choosing Foodie Express. Your delicious meal is being prepared and will be delivered shortly.
            </p>
            
            <div class="order-info-box p-3 rounded-4 mb-4 d-inline-block px-4">
                <span style="color: var(--text-muted); font-size: 0.8rem;" class="fw-bold text-uppercase">Tracking Order</span>
                <p class="mb-0 fw-bold mt-1" style="color: var(--text-main);">We will send updates to your email.</p>
            </div>
            
            <div class="pt-2">
                <a href="/Menu/listFoods" class="btn-continue">
                    <i class="fas fa-shopping-bag me-2"></i> Continue Shopping
                </a>
            </div>
        </div>
    </div>
  </main>

  <%- include('../partials/footer.ejs') %>
</body>
</html>