<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chỉnh sửa món ăn - Foodie Express</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    <!-- Theme Management -->
    <link rel="stylesheet" href="/css/theme.css">
    <script src="/js/theme-manager.js"></script>
    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <style>
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-body); }
        .font-outfit { font-family: 'Outfit', sans-serif; }
        
        .form-card {
            background: var(--bg-card);
            border-radius: 2rem;
            border: 1px solid var(--border-color);
            padding: 3rem;
            max-width: 600px;
            margin: 2rem auto;
            box-shadow: var(--shadow-sm);
        }
        
        .form-label {
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            margin-bottom: 0.8rem;
        }
        
        .form-control {
            border-radius: 12px;
            padding: 0.8rem 1.2rem;
            border: 1px solid var(--border-color);
            background-color: var(--input-bg);
            color: var(--text-main);
            transition: all 0.2s;
        }
        .form-control:focus {
            background-color: var(--bg-card);
            border-color: #ff6347;
            box-shadow: 0 0 0 4px rgba(255, 99, 71, 0.1);
        }
        
        .btn-update-food {
            background: linear-gradient(135deg, #0d6efd 0%, #00d2ff 100%);
            border: none;
            color: #fff;
            font-weight: 700;
            padding: 1rem;
            border-radius: 15px;
            margin-top: 1rem;
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.2);
            transition: all 0.3s;
        }
        .btn-update-food:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(13, 110, 253, 0.3);
            color: #fff;
        }
        
        .image-preview-box {
            width: 100%;
            height: 220px;
            border-radius: 15px;
            background-color: #f8f9fa;
            border: 2px dashed #eee;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin-bottom: 2rem;
            position: relative;
        }
        .image-preview-box img { width: 100%; height: 100%; object-fit: cover; }
        .edit-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background: rgba(0,0,0,0.5);
            color: #fff;
            padding: 5px 12px;
            border-radius: 50px;
            font-size: 0.7rem;
            backdrop-filter: blur(4px);
        }
    </style>
</head>
<body>
    <%- include('../partials/admin_sidebar.ejs', { page: 'products', user: locals.user }) %>

    <div class="main-content">
        <!-- Header -->
        <div class="d-flex align-items-center mb-4" data-aos="fade-down">
            <a href="/admin/products" class="btn btn-white shadow-sm rounded-circle me-3" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-arrow-left text-dark"></i>
            </a>
            <div>
                <h2 class="fw-bold font-outfit m-0 text-dark">Chỉnh sửa món ăn</h2>
                <p class="text-muted small m-0">Cập nhật thông tin chi tiết cho món ăn này</p>
            </div>
        </div>

        <div class="form-card shadow-sm" data-aos="fade-up">
            <div class="image-preview-box">
                <span class="edit-badge"><i class="fas fa-camera me-1"></i> Ảnh hiện tại</span>
                <img src="<%= product.imageUrl %>" id="previewImg">
            </div>

            <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label for="name" class="form-label">Tên món ăn</label>
                        <input type="text" class="form-control" id="name" name="name" value="<%= product.name %>" required />
                    </div>
                    <div class="col-md-12">
                        <label for="description" class="form-label">Mô tả ngắn</label>
                        <textarea class="form-control" id="description" name="description" rows="3" required><%= product.description %></textarea>
                    </div>
                    <div class="col-md-6">
                        <label for="price" class="form-label">Giá bán (VNĐ)</label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="price" name="price" value="<%= product.price %>" required />
                            <span class="input-group-text bg-white border-start-0 text-muted">đ</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label for="category" class="form-label">Danh mục</label>
                        <select class="form-select form-control" id="category" name="category" required>
                            <option value="Món chính" <%= product.category === 'Món chính' ? 'selected' : '' %>>Món chính</option>
                            <option value="Khai vị" <%= product.category === 'Khai vị' ? 'selected' : '' %>>Khai vị</option>
                            <option value="Tráng miệng" <%= product.category === 'Tráng miệng' ? 'selected' : '' %>>Tráng miệng</option>
                            <option value="Đồ uống" <%= product.category === 'Đồ uống' ? 'selected' : '' %>>Đồ uống</option>
                            <option value="Ăn vặt" <%= product.category === 'Ăn vặt' ? 'selected' : '' %>>Ăn vặt</option>
                        </select>
                    </div>
                    <div class="col-md-12">
                        <label for="image" class="form-label">Tải ảnh mới (Tùy chọn)</label>
                        <input type="file" class="form-control" id="image" name="image" accept="image/*" onchange="previewNewImage(this)" />
                        <input type="hidden" name="imageUrl" value="<%= product.imageUrl %>" />
                        <p class="text-muted small mt-2"><i class="fas fa-info-circle me-1"></i> Để trống nếu không muốn thay đổi ảnh.</p>
                    </div>
                </div>
                <button type="submit" class="btn btn-update-food w-100 shadow">
                    <i class="fas fa-save me-2"></i> Lưu thay đổi
                </button>
            </form>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ once: true });
        
        function previewNewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.querySelector('.edit-badge').innerHTML = '<i class="fas fa-camera me-1"></i> Ảnh mới chọn';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>
</html>