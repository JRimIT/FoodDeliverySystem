<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Món ăn - Foodie Express</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <!-- Theme Management -->
    <link rel="stylesheet" href="/css/theme.css">
    <script src="/js/theme-manager.js"></script>
    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <style>
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-body); }
        .font-outfit { font-family: 'Outfit', sans-serif; }
        
        .management-card {
            background: var(--bg-card);
            border-radius: 1.5rem;
            border: none;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            overflow: hidden;
        }
        
        /* Premium Table Styles */
        .table-premium thead th {
            background-color: var(--bg-body);
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid #f1f1f1;
        }
        .table-premium tbody td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #f8f9fa;
            vertical-align: middle;
            font-size: 0.85rem;
        }
        .table-premium tbody tr:hover td {
            background-color: #fff9f8;
        }
        
        .product-img-circle {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }
        
        .badge-category {
            padding: 0.4rem 0.8rem;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.7rem;
            background: #fff5f5;
            color: #ff6347;
            text-transform: uppercase;
        }
        
        .btn-action {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            border: 1px solid #eee;
            background: #fff;
            color: #666;
            text-decoration: none;
        }
        .btn-edit:hover { background: #0d6efd; color: #fff; border-color: #0d6efd; }
        .btn-delete:hover { background: #dc3545; color: #fff; border-color: #dc3545; }
        
        .btn-add-product {
            background: linear-gradient(135deg, #ff6347 0%, #fbc02d 100%);
            border: none;
            color: #fff;
            font-weight: 700;
            padding: 0.6rem 1.5rem;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(255, 99, 71, 0.2);
            transition: all 0.3s;
        }
        .btn-add-product:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 99, 71, 0.3);
            color: #fff;
        }
    </style>
</head>
<body>
    <%- include('../partials/admin_sidebar.ejs', { page: 'products', user: locals.user }) %>

    <div class="main-content">
        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4" data-aos="fade-down">
            <div>
                <h2 class="fw-bold font-outfit m-0 text-dark">Quản lý Thực đơn</h2>
                <p class="text-muted small m-0">Danh sách các món ăn hiện có trong hệ thống</p>
            </div>
            <a href="/admin/products/create" class="btn btn-add-product">
                <i class="fas fa-plus me-2"></i> Thêm món ăn mới
            </a>
        </div>

        <!-- Products Table Card -->
        <div class="management-card shadow-sm" data-aos="fade-up">
            <div class="table-responsive">
                <table class="table table-premium mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá bán</th>
                            <th>Ngày tạo</th>
                            <th class="text-center pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach((product, index) => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="<%= product.imageUrl %>" class="product-img-circle me-3" alt="<%= product.name %>">
                                        <div>
                                            <div class="fw-bold text-dark"><%= product.name %></div>
                                            <div class="text-muted small">ID: #<%= product._id.toString().slice(-6).toUpperCase() %></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge-category"><%= product.category %></span>
                                </td>
                                <td>
                                    <div class="fw-bold text-danger"><%= product.price.toLocaleString('vi-VN') %>đ</div>
                                </td>
                                <td>
                                    <div class="text-muted small"><%= new Date(product.createdAt).toLocaleDateString('vi-VN') %></div>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="/admin/products/edit/<%= product._id %>" class="btn-action btn-edit" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form action="/admin/products/delete/<%= product._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa món ăn này?');">
                                            <button type="submit" class="btn-action btn-delete" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (products.length === 0) { %>
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="text-muted">Chưa có món ăn nào trong thực đơn.</div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ once: true });
    </script>
</body>
</html>