<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thêm món ăn - Foodie Express</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    <!-- Theme Management -->
    <link rel="stylesheet" href="/css/theme.css">
    <script src="/js/theme-manager.js"></script>
    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <style>
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-body); }
        .font-outfit { font-family: 'Outfit', sans-serif; }
        
        .form-card {
            background: var(--bg-card);
            border-radius: 2rem;
            border: 1px solid var(--border-color);
            padding: 3rem;
            max-width: 600px;
            margin: 2rem auto;
            box-shadow: var(--shadow-sm);
        }
        
        .form-label {
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            margin-bottom: 0.8rem;
        }
        
        .form-control {
            border-radius: 12px;
            padding: 0.8rem 1.2rem;
            border: 1px solid var(--border-color);
            background-color: var(--input-bg);
            color: var(--text-main);
            transition: all 0.2s;
        }
        .form-control:focus {
            background-color: var(--bg-card);
            border-color: #ff6347;
            box-shadow: 0 0 0 4px rgba(255, 99, 71, 0.1);
        }
        
        .btn-submit-food {
            background: linear-gradient(135deg, #ff6347 0%, #fbc02d 100%);
            border: none;
            color: #fff;
            font-weight: 700;
            padding: 1rem;
            border-radius: 15px;
            margin-top: 1rem;
            box-shadow: 0 4px 15px rgba(255, 99, 71, 0.2);
            transition: all 0.3s;
        }
        .btn-submit-food:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(255, 99, 71, 0.3);
            color: #fff;
        }
        
        .image-preview-box {
            width: 100%;
            height: 200px;
            border-radius: 15px;
            background-color: #f8f9fa;
            border: 2px dashed #eee;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin-bottom: 1.5rem;
        }
        #previewImg { width: 100%; height: 100%; object-fit: cover; display: none; }
    </style>
</head>
<body>
    <%- include('../partials/admin_sidebar.ejs', { page: 'products', user: locals.user }) %>

    <div class="main-content">
        <!-- Header -->
        <div class="d-flex align-items-center mb-4" data-aos="fade-down">
            <a href="/admin/products" class="btn btn-white shadow-sm rounded-circle me-3" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-arrow-left text-dark"></i>
            </a>
            <div>
                <h2 class="fw-bold font-outfit m-0 text-dark">Thêm món mới</h2>
                <p class="text-muted small m-0">Tạo món ăn mới cho thực đơn của bạn</p>
            </div>
        </div>

        <div class="form-card shadow-sm" data-aos="fade-up">
            <div id="imagePreview" class="image-preview-box">
                <i class="fas fa-image fa-3x text-muted opacity-25" id="placeholderIcon"></i>
                <img src="" id="previewImg">
            </div>

            <form action="/admin/products/create" method="POST">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label for="name" class="form-label">Tên món ăn</label>
                        <input type="text" class="form-control" id="name" name="name" placeholder="Ví dụ: Phở Bò Tái Lăn" required />
                    </div>
                    <div class="col-md-12">
                        <label for="description" class="form-label">Mô tả ngắn</label>
                        <textarea class="form-control" id="description" name="description" rows="3" placeholder="Mô tả hương vị, nguyên liệu..." required></textarea>
                    </div>
                    <div class="col-md-6">
                        <label for="price" class="form-label">Giá bán (VNĐ)</label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="price" name="price" min="0" placeholder="50000" required />
                            <span class="input-group-text bg-white border-start-0 text-muted">đ</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label for="category" class="form-label">Danh mục</label>
                        <select class="form-select form-control" id="category" name="category" required>
                            <option value="" selected disabled>Chọn loại...</option>
                            <option value="Món chính">Món chính</option>
                            <option value="Khai vị">Khai vị</option>
                            <option value="Tráng miệng">Tráng miệng</option>
                            <option value="Đồ uống">Đồ uống</option>
                            <option value="Ăn vặt">Ăn vặt</option>
                        </select>
                    </div>
                    <div class="col-md-12">
                        <label for="imageUrl" class="form-label">Đường dẫn ảnh (URL)</label>
                        <input type="text" class="form-control" id="imageUrl" name="imageUrl" placeholder="https://image-url.com/food.jpg" required onchange="updatePreview(this.value)" />
                    </div>
                </div>
                <button type="submit" class="btn btn-submit-food w-100 shadow">
                    <i class="fas fa-plus-circle me-2"></i> Xác nhận thêm món
                </button>
            </form>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ once: true });
        
        function updatePreview(url) {
            const preview = document.getElementById('previewImg');
            const placeholder = document.getElementById('placeholderIcon');
            if (url) {
                preview.src = url;
                preview.style.display = 'block';
                placeholder.style.display = 'none';
            } else {
                preview.style.display = 'none';
                placeholder.style.display = 'block';
            }
        }
    </script>
</body>
</html>