<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Người dùng - Foodie Express</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <!-- Theme Management -->
    <link rel="stylesheet" href="/css/theme.css">
    <script src="/js/theme-manager.js"></script>
    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <style>
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-body); }
        .font-outfit { font-family: 'Outfit', sans-serif; }
        
        .management-card {
            background: var(--bg-card);
            border-radius: 1.5rem;
            border: none;
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }
        
        .table-premium thead th {
            background-color: var(--bg-body);
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }
        .table-premium tbody td {
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            font-size: 0.85rem;
        }
        .table-premium tbody tr:hover td {
            background-color: var(--input-bg);
        }
        
        .role-badge {
            padding: 0.4rem 1rem;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.7rem;
            text-transform: uppercase;
        }
        .role-admin { background: #ffebee; color: #c62828; }
        .role-shipper { background: #e3f2fd; color: #1976d2; }
        .role-customer { background: #e8f5e9; color: #2e7d32; }
        
        .user-avatar-sm {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            object-fit: cover;
            border: 2px solid #fff;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }
        
        .btn-action-user {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            border: 1px solid #eee;
            background: #fff;
            color: #666;
            text-decoration: none;
        }
        .btn-edit:hover { background: #0d6efd; color: #fff; border-color: #0d6efd; }
        .btn-delete:hover { background: #dc3545; color: #fff; border-color: #dc3545; }
    </style>
</head>
<body>
    <%- include('../partials/admin_sidebar.ejs', { page: 'users', user: locals.user }) %>

    <div class="main-content">
        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4" data-aos="fade-down">
            <div>
                <h2 class="fw-bold font-outfit m-0 text-dark">Quản lý Người dùng</h2>
                <p class="text-muted small m-0">Danh sách các tài khoản đang hoạt động trong hệ thống</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-white shadow-sm rounded-pill px-4 py-2 fw-bold small"><i class="fas fa-user-plus me-2"></i> Thêm User</button>
            </div>
        </div>

        <!-- Users Table Card -->
        <div class="management-card shadow-sm" data-aos="fade-up">
            <div class="table-responsive">
                <table class="table table-premium mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Người dùng</th>
                            <th>Email / Username</th>
                            <th>Vai trò</th>
                            <th>Ngày tham gia</th>
                            <th class="text-center pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach((u, index) => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="<%= u.avatarUrl || 'https://i.pinimg.com/1200x/dc/6c/b0/dc6cb0521d182f959da46aaee82e742f.jpg' %>" class="user-avatar-sm me-3" alt="<%= u.username %>">
                                        <div>
                                            <div class="fw-bold text-dark"><%= u.name || u.username %></div>
                                            <div class="text-muted small">UID: #<%= u._id.toString().slice(-6).toUpperCase() %></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="text-dark fw-medium"><%= u.username %></div>
                                    <div class="text-muted" style="font-size: 0.75rem;"><%= u.email || 'N/A' %></div>
                                </td>
                                <td>
                                    <% if (u.role === 'admin') { %>
                                        <span class="role-badge role-admin">Administrator</span>
                                    <% } else if (u.role === 'shipper') { %>
                                        <span class="role-badge role-shipper">Shipper</span>
                                    <% } else { %>
                                        <span class="role-badge role-customer">Khách hàng</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="text-muted small"><%= new Date(u.createdAt).toLocaleDateString('vi-VN') %></div>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="/admin/users/edit/<%= u._id %>" class="btn-action-user btn-edit" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form id="deleteForm-<%= u._id %>" action="/admin/users/delete/<%= u._id %>" method="POST" class="d-inline">
                                            <button type="button" class="btn-action-user btn-delete" onclick="confirmDelete('<%= u._id %>')" title="Xóa">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ once: true });
        
        function confirmDelete(userId) {
            Swal.fire({
                title: 'Xóa người dùng?',
                text: "Dữ liệu người dùng này sẽ bị xóa vĩnh viễn khỏi hệ thống.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#adb5bd',
                confirmButtonText: 'Đúng, xóa ngay!',
                cancelButtonText: 'Hủy bỏ',
                reverseButtons: true,
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(`deleteForm-${userId}`).submit();
                }
            });
        }
    </script>
</body>
</html>