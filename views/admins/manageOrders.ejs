<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Đơn hàng - Foodie Express</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <!-- Theme Management -->
    <link rel="stylesheet" href="/css/theme.css">
    <script src="/js/theme-manager.js"></script>
    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <style>
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-body); }
        .font-outfit { font-family: 'Outfit', sans-serif; }
        
        .management-card {
            background: var(--bg-card);
            border-radius: 1.5rem;
            border: none;
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }
        
        .table-premium thead th {
            background-color: var(--bg-body);
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }
        .table-premium tbody td {
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            font-size: 0.85rem;
        }
        .table-premium tbody tr:hover td {
            background-color: var(--input-bg);
        }
        
        .status-pill {
            padding: 0.4rem 1rem;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.7rem;
            text-transform: uppercase;
        }
        .status-pending { background: #fff8e1; color: #ffa000; }
        .status-processing { background: #e3f2fd; color: #1976d2; }
        .status-shipping { background: #f3e5f5; color: #7b1fa2; }
        .status-completed { background: #e8f5e9; color: #2e7d32; }
        .status-cancelled { background: #ffebee; color: #c62828; }
        
        .order-id { font-family: monospace; font-weight: 700; color: #495057; background: #f8f9fa; padding: 2px 8px; border-radius: 4px; }
        
        .btn-update-status {
            background: #ff6347;
            border: none;
            color: #fff;
            font-weight: 700;
            font-size: 0.75rem;
            padding: 0.4rem 1rem;
            border-radius: 8px;
            transition: all 0.2s;
        }
        .btn-update-status:hover { background: #e5533d; transform: translateY(-1px); }
        
        .items-list { list-style: none; padding: 0; margin: 0; }
        .items-list li { font-size: 0.8rem; color: #666; margin-bottom: 2px; }
        .items-list li strong { color: #333; }
    </style>
</head>
<body>
    <%- include('../partials/admin_sidebar.ejs', { page: 'orders', user: locals.user }) %>

    <div class="main-content">
        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4" data-aos="fade-down">
            <div>
                <h2 class="fw-bold font-outfit m-0 text-dark">Quản lý Đơn hàng</h2>
                <p class="text-muted small m-0">Theo dõi và cập nhật trạng thái đơn hàng của khách hàng</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-white shadow-sm rounded-pill px-4 py-2 fw-bold small"><i class="fas fa-filter me-2"></i> Bộ lọc</button>
            </div>
        </div>

        <!-- Orders Table Card -->
        <div class="management-card shadow-sm" data-aos="fade-up">
            <div class="table-responsive">
                <table class="table table-premium mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Mã Đơn</th>
                            <th>Khách hàng</th>
                            <th>Thực đơn</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Ngày đặt</th>
                            <th class="text-center pe-4">Cập nhật</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (orders.length === 0) { %>
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="text-muted">Chưa có đơn hàng nào trong hệ thống.</div>
                                </td>
                            </tr>
                        <% } %>
                        <% orders.forEach((order, index) => { %>
                            <tr>
                                <td class="ps-4">
                                    <span class="order-id">#<%= order._id.toString().slice(-8).toUpperCase() %></span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark"><%= order.userId ? order.userId.username : 'N/A' %></div>
                                    <div class="text-muted small text-truncate" style="max-width: 150px;" title="<%= order.address %>">
                                        <i class="fas fa-map-marker-alt me-1 text-danger"></i> <%= order.address %>
                                    </div>
                                </td>
                                <td>
                                    <ul class="items-list">
                                        <% order.items.forEach(item => { %>
                                            <li><strong><%= item.quantity %>x</strong> <%= item.productId ? item.productId.name : 'N/A' %></li>
                                        <% }) %>
                                    </ul>
                                </td>
                                <td>
                                    <div class="fw-bold text-danger"><%= order.totalPrice.toLocaleString('vi-VN') %>đ</div>
                                    <div class="text-muted" style="font-size: 0.7rem;"><i class="fas fa-wallet me-1"></i> <%= order.paymentMethod %></div>
                                </td>
                                <td>
                                    <% if (order.status === 'Pending') { %><span class="status-pill status-pending">Đang chờ</span>
                                    <% } else if (order.status === 'Processing') { %><span class="status-pill status-processing">Đang chuẩn bị</span>
                                    <% } else if (order.status === 'Shipping') { %><span class="status-pill status-shipping">Đang giao</span>
                                    <% } else if (order.status === 'Completed') { %><span class="status-pill status-completed">Đã xong</span>
                                    <% } else if (order.status === 'Cancelled') { %><span class="status-pill status-cancelled">Đã hủy</span>
                                    <% } else { %><span class="badge bg-secondary"><%= order.status %></span><% } %>
                                </td>
                                <td>
                                    <div class="text-dark small fw-bold"><%= new Date(order.createdAt).toLocaleDateString('vi-VN') %></div>
                                    <div class="text-muted" style="font-size: 0.7rem;"><%= new Date(order.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></div>
                                </td>
                                <td class="text-center pe-4">
                                    <form class="d-flex gap-2 align-items-center justify-content-center" action="/admin/orders/update/<%= order._id %>" method="POST">
                                        <select name="status" class="form-select form-select-sm rounded-3 shadow-none border-light" style="width: 120px; font-size: 0.8rem;">
                                            <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Đang chờ</option>
                                            <option value="Processing" <%= order.status === 'Processing' ? 'selected' : '' %>>Chuẩn bị</option>
                                            <option value="Shipping" <%= order.status === 'Shipping' ? 'selected' : '' %>>Giao hàng</option>
                                            <option value="Completed" <%= order.status === 'Completed' ? 'selected' : '' %>>Hoàn thành</option>
                                            <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Hủy đơn</option>
                                        </select>
                                        <button type="submit" class="btn-update-status shadow-sm">
                                            Lưu
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ once: true });
    </script>
</body>
</html>