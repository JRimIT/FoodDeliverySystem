<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Đơn hàng - Foodie Express</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <!-- Theme Management -->
    <link rel="stylesheet" href="/css/theme.css">
    <script src="/js/theme-manager.js"></script>
    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <style>
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-body); }
        .font-outfit { font-family: 'Outfit', sans-serif; }
        
        .management-card {
            background: var(--bg-card);
            border-radius: 1.5rem;
            border: none;
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }
        
        .table-premium thead th {
            background-color: var(--bg-body);
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }
        .table-premium tbody td {
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            font-size: 0.85rem;
        }
        .table-premium tbody tr:hover td {
            background-color: var(--input-bg);
        }
        
        .status-pill {
            padding: 0.4rem 1rem;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.7rem;
            text-transform: uppercase;
        }
        .status-pending { background: #fff8e1; color: #ffa000; }
        .status-processing { background: #e3f2fd; color: #1976d2; }
        .status-shipping { background: #f3e5f5; color: #7b1fa2; }
        .status-completed { background: #e8f5e9; color: #2e7d32; }
        .status-cancelled { background: #ffebee; color: #c62828; }
        
        .order-id { font-family: monospace; font-weight: 700; color: #495057; background: #f8f9fa; padding: 2px 8px; border-radius: 4px; }
        
        .btn-update-status {
            background: #ff6347;
            border: none;
            color: #fff;
            font-weight: 700;
            font-size: 0.75rem;
            padding: 0.4rem 1rem;
            border-radius: 8px;
            transition: all 0.2s;
        }
        .btn-update-status:hover { background: #e5533d; transform: translateY(-1px); }
        
        .items-list { list-style: none; padding: 0; margin: 0; }
        .items-list li { font-size: 0.8rem; color: #666; margin-bottom: 2px; }
        .items-list li strong { color: #333; }

        .filter-option-card {
            background-color: var(--input-bg) !important;
            border: 1px solid var(--border-color) !important;
            border-radius: 12px !important;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
        }
        .filter-option-card:hover {
            background-color: var(--bg-body) !important;
            border-color: #ff6347 !important;
        }
        .filter-option-card .form-check-label {
            color: var(--text-main) !important;
            cursor: pointer;
            font-weight: 600;
        }
        .filter-option-card .form-check-input {
            margin-top: 0;
            cursor: pointer;
            border-color: var(--border-color);
        }
        
        /* Modal header styling in dark mode */
        [data-theme="dark"] .modal-content {
            background-color: var(--bg-card) !important;
            color: var(--text-main) !important;
        }
        [data-theme="dark"] .modal-header .btn-close {
            filter: invert(1);
        }
    </style>
</head>
<body>
    <%- include('../partials/admin_sidebar.ejs', { page: 'orders', user: locals.user }) %>

    <div class="main-content">
        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4" data-aos="fade-down">
            <div>
                <h2 class="fw-bold font-outfit m-0">Quản lý Đơn hàng</h2>
                <p class="text-muted small m-0 mt-1">Theo dõi và cập nhật trạng thái đơn hàng của khách hàng</p>
            </div>
        </div>

        <!-- Inline Advanced Filter Card -->
        <div class="card border-0 shadow-sm p-4 rounded-4 mb-4" style="background: var(--bg-card);" data-aos="fade-up">
            <form action="/admin/orders" method="GET" id="filterForm">
                <div class="row g-3 align-items-end">
                    <!-- Search by Customer Name -->
                    <div class="col-md-3 col-sm-6">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2"><i class="fas fa-search me-1"></i> Tên khách hàng</label>
                        <div class="input-group">
                            <span class="input-group-text bg-body border-end-0 text-muted" style="border-color: var(--border-color);"><i class="fas fa-user"></i></span>
                            <input type="text" name="search" class="form-control bg-body border-start-0 text-main" style="border-color: var(--border-color);" placeholder="Nhập tên khách hàng..." value="<%= search || '' %>">
                        </div>
                    </div>

                    <!-- Filter by Status -->
                    <div class="col-md-2 col-sm-6">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2"><i class="fas fa-info-circle me-1"></i> Trạng thái</label>
                        <select name="status" class="form-select bg-body text-main" style="border-color: var(--border-color);" onchange="this.form.submit()">
                            <option value="all" <%= status === 'all' ? 'selected' : '' %>>Tất cả trạng thái</option>
                            <option value="Pending" <%= status === 'Pending' ? 'selected' : '' %>>Đang chờ</option>
                            <option value="Processing" <%= status === 'Processing' ? 'selected' : '' %>>Chuẩn bị</option>
                            <option value="Shipping" <%= status === 'Shipping' ? 'selected' : '' %>>Giao hàng</option>
                            <option value="Completed" <%= status === 'Completed' ? 'selected' : '' %>>Hoàn thành</option>
                            <option value="Cancelled" <%= status === 'Cancelled' ? 'selected' : '' %>>Hủy đơn</option>
                        </select>
                    </div>

                    <!-- Filter by Date -->
                    <div class="col-md-3 col-sm-6">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2"><i class="fas fa-calendar-alt me-1"></i> Mốc thời gian</label>
                        <select id="dateSelect" class="form-select bg-body text-main" style="border-color: var(--border-color);" onchange="handleDateSelectChange(this.value)" <%= (selectedDate !== 'today' && selectedDate !== 'all') ? '' : 'name=date' %>>
                            <option value="today" <%= selectedDate === 'today' ? 'selected' : '' %>>Hôm nay trở về sau (Mặc định)</option>
                            <option value="all" <%= selectedDate === 'all' ? 'selected' : '' %>>Tất cả đơn hàng</option>
                            <option value="custom" <%= (selectedDate !== 'today' && selectedDate !== 'all') ? 'selected' : '' %>>Tùy chọn ngày trở về sau...</option>
                        </select>
                        <input type="date" id="customDateInput" class="form-control bg-body text-main rounded-3 mt-2 <%= (selectedDate !== 'today' && selectedDate !== 'all') ? '' : 'd-none' %>" style="border-color: var(--border-color);" value="<%= (selectedDate !== 'today' && selectedDate !== 'all') ? selectedDate : '' %>" <%= (selectedDate !== 'today' && selectedDate !== 'all') ? 'name=date' : '' %> onchange="this.form.submit()">
                    </div>

                    <!-- Sort Order -->
                    <div class="col-md-2 col-sm-6">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2"><i class="fas fa-sort me-1"></i> Thứ tự ngày</label>
                        <select name="sort" class="form-select bg-body text-main" style="border-color: var(--border-color);" onchange="this.form.submit()">
                            <option value="desc" <%= sort === 'desc' ? 'selected' : '' %>>Mới nhất trước</option>
                            <option value="asc" <%= sort === 'asc' ? 'selected' : '' %>>Cũ nhất trước</option>
                        </select>
                    </div>

                    <!-- Action Buttons -->
                    <div class="col-md-2 col-sm-6 d-flex gap-2">
                        <button type="submit" class="btn btn-danger w-100 fw-bold rounded-3 py-2 text-white shadow-sm" style="background-color: #ff6347; border: none;"><i class="fas fa-filter me-1"></i> Lọc</button>
                        <a href="/admin/orders" class="btn btn-secondary fw-semibold rounded-3 py-2 text-decoration-none text-center" style="min-width: 50px;"><i class="fas fa-undo"></i></a>
                    </div>
                </div>
            </form>
        </div>

        <!-- Orders Table Card -->
        <div class="management-card shadow-sm" data-aos="fade-up">
            <div class="table-responsive">
                <table class="table table-premium mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Mã Đơn</th>
                            <th>Khách hàng</th>
                            <th>Thực đơn</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Ngày đặt</th>
                            <th class="text-center pe-4">Cập nhật</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (orders.length === 0) { %>
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="text-muted">Chưa có đơn hàng nào trong hệ thống.</div>
                                </td>
                            </tr>
                        <% } %>
                        <% orders.forEach((order, index) => { %>
                            <tr>
                                <td class="ps-4">
                                    <span class="order-id">#<%= order._id.toString().slice(-8).toUpperCase() %></span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark"><%= order.userId ? order.userId.username : 'N/A' %></div>
                                    <div class="text-muted small text-truncate" style="max-width: 150px;" title="<%= order.address %>">
                                        <i class="fas fa-map-marker-alt me-1 text-danger"></i> <%= order.address %>
                                    </div>
                                </td>
                                <td>
                                    <ul class="items-list">
                                        <% order.items.forEach(item => { %>
                                            <li><strong><%= item.quantity %>x</strong> <%= item.productId ? item.productId.name : 'N/A' %></li>
                                        <% }) %>
                                    </ul>
                                </td>
                                <td>
                                    <div class="fw-bold text-danger"><%= order.totalPrice.toLocaleString('vi-VN') %>đ</div>
                                    <div class="text-muted" style="font-size: 0.7rem;"><i class="fas fa-wallet me-1"></i> <%= order.paymentMethod %></div>
                                </td>
                                <td>
                                    <% if (order.status === 'Pending') { %><span class="status-pill status-pending">Đang chờ</span>
                                    <% } else if (order.status === 'Processing') { %><span class="status-pill status-processing">Đang chuẩn bị</span>
                                    <% } else if (order.status === 'Shipping') { %><span class="status-pill status-shipping">Đang giao</span>
                                    <% } else if (order.status === 'Completed') { %><span class="status-pill status-completed">Đã xong</span>
                                    <% } else if (order.status === 'Cancelled') { %><span class="status-pill status-cancelled">Đã hủy</span>
                                    <% } else { %><span class="badge bg-secondary"><%= order.status %></span><% } %>
                                </td>
                                <td>
                                    <div class="text-dark small fw-bold"><%= new Date(order.createdAt).toLocaleDateString('vi-VN') %></div>
                                    <div class="text-muted" style="font-size: 0.7rem;"><%= new Date(order.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></div>
                                </td>
                                <td class="text-center pe-4">
                                    <form class="d-flex gap-2 align-items-center justify-content-center" action="/admin/orders/update/<%= order._id %>" method="POST">
                                        <select name="status" class="form-select form-select-sm rounded-3 shadow-none border-light" style="width: 120px; font-size: 0.8rem;">
                                            <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Đang chờ</option>
                                            <option value="Processing" <%= order.status === 'Processing' ? 'selected' : '' %>>Chuẩn bị</option>
                                            <option value="Shipping" <%= order.status === 'Shipping' ? 'selected' : '' %>>Giao hàng</option>
                                            <option value="Completed" <%= order.status === 'Completed' ? 'selected' : '' %>>Hoàn thành</option>
                                            <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Hủy đơn</option>
                                        </select>
                                        <button type="submit" class="btn-update-status shadow-sm">
                                            Lưu
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ once: true });

        function handleDateSelectChange(val) {
            const select = document.getElementById('dateSelect');
            const customInput = document.getElementById('customDateInput');
            if (val === 'custom') {
                customInput.classList.remove('d-none');
                select.removeAttribute('name');
                customInput.setAttribute('name', 'date');
                if (!customInput.value) {
                    customInput.value = new Date().toISOString().split('T')[0];
                }
            } else {
                customInput.classList.add('d-none');
                select.setAttribute('name', 'date');
                customInput.removeAttribute('name');
                select.form.submit();
            }
        }
    </script>
</body>
</html>