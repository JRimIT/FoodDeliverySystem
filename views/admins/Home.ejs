<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Admin - Foodie Express</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    <!-- AOS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <!-- Theme Management -->
    <link rel="stylesheet" href="/css/theme.css">
    <script src="/js/theme-manager.js"></script>
    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <style>
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-body); }
        .font-outfit { font-family: 'Outfit', sans-serif; }
        
        .stat-card {
            background: var(--bg-card);
            border-radius: 1.5rem;
            border: 1px solid var(--border-color);
            padding: 1.5rem;
            transition: all 0.3s ease;
            height: 100%;
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-md);
        }
        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            margin-bottom: 1rem;
        }
        
        .management-card {
            background: var(--bg-card);
            border-radius: 2rem;
            border: 1px solid var(--border-color);
            padding: 2rem;
            transition: all 0.3s ease;
            text-decoration: none;
            display: block;
            text-align: center;
        }
        .management-card:hover {
            border-color: #ff6347;
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(255, 99, 71, 0.1);
        }
        .management-icon {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: #fff5f5;
            color: #ff6347;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 1.5rem;
            transition: all 0.3s;
        }
        .management-card:hover .management-icon {
            background: linear-gradient(135deg, #ff6347 0%, #fbc02d 100%);
            color: #fff;
            transform: rotate(10deg);
        }
        
        .welcome-hero {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            border-radius: 2rem;
            padding: 3rem;
            color: #fff;
            margin-bottom: 3rem;
            position: relative;
            overflow: hidden;
        }
        .welcome-hero::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255, 99, 71, 0.1);
            border-radius: 50%;
            filter: blur(50px);
        }
    </style>
</head>
<body>
    <%- include('../partials/admin_sidebar.ejs', { page: 'dashboard', user: locals.user }) %>

    <div class="main-content">
        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4" data-aos="fade-down">
            <div>
                <h2 class="fw-bold font-outfit m-0 text-dark">Hệ thống Quản trị</h2>
                <p class="text-muted small m-0">Chào mừng trở lại, quản trị viên!</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-white shadow-sm rounded-pill px-3 py-2 fw-bold small"><i class="far fa-calendar me-2"></i> <%= new Date().toLocaleDateString('vi-VN') %></button>
            </div>
        </div>

        <!-- Welcome Section -->
        <div class="welcome-hero shadow-lg" data-aos="zoom-in" data-aos-delay="100">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="display-5 fw-bold font-outfit mb-3">Xin chào, <%= user.name || 'Admin' %>! 👋</h1>
                    <p class="lead opacity-75 mb-4">Mọi thứ đang hoạt động ổn định. Bạn có muốn kiểm tra các đơn hàng mới nhất không?</p>
                    <a href="/admin/orders" class="btn btn-danger rounded-pill px-4 py-2 fw-bold shadow-sm">Xem đơn hàng ngay</a>
                </div>
                <div class="col-md-4 text-center d-none d-md-block">
                    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" width="180" class="img-fluid drop-shadow" alt="Admin">
                </div>
            </div>
        </div>

        <!-- Quick Management Grid -->
        <h4 class="fw-bold font-outfit mb-4 text-dark" data-aos="fade-right">Trung tâm Quản lý</h4>
        <div class="row g-4 mb-5">
            <div class="col-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                <a href="/admin/manageUser" class="management-card">
                    <div class="management-icon shadow-sm"><i class="fas fa-users"></i></div>
                    <h6 class="fw-bold text-dark mb-1">Người dùng</h6>
                    <p class="text-muted small mb-0">Quản lý tài khoản</p>
                </a>
            </div>
            <div class="col-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                <a href="/admin/products" class="management-card">
                    <div class="management-icon shadow-sm"><i class="fas fa-utensils"></i></div>
                    <h6 class="fw-bold text-dark mb-1">Thực đơn</h6>
                    <p class="text-muted small mb-0">Chỉnh sửa món ăn</p>
                </a>
            </div>
            <div class="col-6 col-lg-3" data-aos="fade-up" data-aos-delay="400">
                <a href="/admin/orders" class="management-card">
                    <div class="management-icon shadow-sm"><i class="fas fa-shopping-bag"></i></div>
                    <h6 class="fw-bold text-dark mb-1">Đơn hàng</h6>
                    <p class="text-muted small mb-0">Xử lý giao hàng</p>
                </a>
            </div>
            <div class="col-6 col-lg-3" data-aos="fade-up" data-aos-delay="500">
                <a href="/admin/reviews" class="management-card">
                    <div class="management-icon shadow-sm"><i class="fas fa-star"></i></div>
                    <h6 class="fw-bold text-dark mb-1">Phản hồi</h6>
                    <p class="text-muted small mb-0">Xem đánh giá</p>
                </a>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="row g-4">
            <div class="col-md-4" data-aos="fade-right" data-aos-delay="600">
                <div class="stat-card">
                    <div class="stat-icon bg-primary-subtle text-primary"><i class="fas fa-chart-line"></i></div>
                    <div class="text-muted small fw-bold text-uppercase">Doanh thu tháng</div>
                    <h2 class="fw-bold font-outfit mt-1">45.2Mđ</h2>
                    <div class="small text-success fw-bold"><i class="fas fa-arrow-up me-1"></i> +12% so với tháng trước</div>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="700">
                <div class="stat-card">
                    <div class="stat-icon bg-success-subtle text-success"><i class="fas fa-shopping-cart"></i></div>
                    <div class="text-muted small fw-bold text-uppercase">Đơn hàng mới</div>
                    <h2 class="fw-bold font-outfit mt-1">128</h2>
                    <div class="small text-muted fw-bold">Đang chờ xử lý: <span class="text-warning">14</span></div>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-left" data-aos-delay="800">
                <div class="stat-card">
                    <div class="stat-icon bg-warning-subtle text-warning"><i class="fas fa-user-plus"></i></div>
                    <div class="text-muted small fw-bold text-uppercase">Thành viên mới</div>
                    <h2 class="fw-bold font-outfit mt-1">+24</h2>
                    <div class="small text-muted fw-bold">Tổng cộng: <span class="text-dark">1,240</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ once: true });
    </script>
</body>
</html>