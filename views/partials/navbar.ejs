           style="background: linear-gradient(135deg, #ff6347 0%, #ff4500 100%) !important; color: white; position: relative;">
        <div class="d-flex align-items-center gap-2">
          <i class="fas fa-wallet fa-lg"></i>
          <h5 class="modal-title fw-bold" id="depositModalLabel" style="margin: 0; color: white !important;">Nạp Tiền Vào Ví</h5>
        </div>
