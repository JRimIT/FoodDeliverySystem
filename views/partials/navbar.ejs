<nav class="navbar navbar-expand-lg navbar-custom fixed-top">
    <div class="container">
        <!-- Logo -->
        <a class="navbar-brand d-flex align-items-center gap-2" href="/Home">
            <img src="https://cdn-icons-png.flaticon.com/512/1046/1046784.png" alt="Logo" width="40" height="40" />
            <span class="fw-bold font-outfit text-dark fs-4">Foodie<span class="text-danger">Express</span></span>
        </a>

        <!-- Toggle for mobile -->
        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Navbar content -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto mb-2 mb-lg-0 text-center">
                <li class="nav-item"><a class="nav-link" href="/Home">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/Menu/listFoods">Menu</a></li>
                <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
                <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
                <li class="nav-item"><a class="nav-link" href="/help">Help</a></li>

                <!-- Admin -->
                <% if (user && user.role === 'admin') { %>
                <li class="nav-item">
                    <a class="nav-link text-primary" href="/admin/Home"> <i class="fas fa-user-shield"></i> Admin </a>
                </li>
                <% } %>

                <!-- Shipper -->
                <% if (user && user.role === 'shipper') { %>
                <li class="nav-item">
                    <a class="nav-link text-primary" href="/shipper/dashboard"> <i class="fas fa-truck"></i> Shipper </a>
                </li>
                <% } %>
            </ul>

            <div class="d-flex flex-column flex-lg-row align-items-center gap-3">
                <!-- Search bar -->
                <form class="d-flex navbar-search" role="search" method="get" action="/Menu/listFoods">
                    <input
                        class="form-control"
                        type="search"
                        name="search"
                        placeholder="Search food..."
                        aria-label="Search"
                        value="<%= typeof search !== 'undefined' ? search : '' %>"
                    />
                    <button class="btn" type="submit"><i class="fas fa-search"></i></button>
                </form>

                <!-- Right Side Actions -->
                <div class="d-flex align-items-center gap-3">
                    <!-- Balance -->
                    <% if (user) { %>
                    <div class="balance-badge text-white shadow-sm d-flex align-items-center gap-1">
                        <i class="fas fa-wallet"></i> 
                        <%= user.balance ? user.balance.toLocaleString('vi-VN') : 0 %>đ
                    </div>
                    <% } %>

                    <!-- Cart Icon -->
                    <% if (typeof cartCount !== 'undefined') { %>
                    <a href="/view/cart" class="text-decoration-none">
                        <div class="cart-wrapper shadow-sm">
                            <i class="fas fa-shopping-cart"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger cart-badge">
                                <%= cartCount %>
                            </span>
                        </div>
                    </a>
                    <% } %>

                    <!-- Avatar or Login -->
                    <% if (user) { %>
                    <div class="dropdown">
                        <a
                            href="#"
                            class="d-flex align-items-center text-decoration-none dropdown-toggle"
                            id="dropdownUser"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                        >
                            <img
                                src="<%= user.avatarUrl || 'https://i.pinimg.com/1200x/dc/6c/b0/dc6cb0521d182f959da46aaee82e742f.jpg' %>"
                                alt="avatar"
                                width="42"
                                height="42"
                                class="rounded-circle user-avatar"
                            />
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="dropdownUser">
                            <li><h6 class="dropdown-header">Hello, <%= user.name || 'User' %>!</h6></li>
                            <li><a class="dropdown-item" href="/profile"><i class="fas fa-user me-2 text-muted"></i> Profile</a></li>
                            <li><a class="dropdown-item" href="/settings"><i class="fas fa-cog me-2 text-muted"></i> Settings</a></li>
                            <li><a class="dropdown-item" href="/orders"><i class="fas fa-box me-2 text-muted"></i> Orders</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item text-danger fw-bold" href="/"><i class="fas fa-sign-out-alt me-2"></i> Logout</a></li>
                        </ul>
                    </div>
                    <% } else { %>
                    <a href="/login" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</nav>
