<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Login - Foodie Express</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="/css/theme.css" />
        <link rel="stylesheet" href="/css/login.css" />
        <script src="/js/theme-manager.js"></script>
        <script>
            (function() {
                const theme = localStorage.getItem('theme') || 'light';
                document.documentElement.setAttribute('data-theme', theme);
            })();
        </script>
    </head>

    <body>
        <div class="auth-wrapper d-flex justify-content-center align-items-center">
            <div class="theme-toggle-wrapper">
                <button onclick="toggleTheme()" class="btn-theme-toggle">
                    <i class="fas fa-moon theme-toggle-icon"></i>
                </button>
            </div>

            <div class="auth-card-compact">
                <div class="text-center mb-3">
                    <h2 class="auth-title-compact font-outfit mb-1">Login</h2>
                    <p class="small text-muted" style="font-size: 0.75rem;">Welcome to Foodie Express</p>
                </div>

                <% if (typeof error !== 'undefined') { %>
                <div class="alert alert-danger small py-1 rounded-3 border-0 mb-3 text-center">
                    <%= error === 'UserNotFound' ? 'User not found' : error === 'InvalidPassword' ? 'Incorrect password' : error %>
                </div>
                <% } %>

                <form action="/auth/login" method="POST">
                    <div class="mb-3">
                        <div class="input-group-compact">
                            <i class="fas fa-user icon"></i>
                            <input type="text" name="username" class="form-control-compact" placeholder="Username" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="input-group-compact">
                            <i class="fas fa-lock icon"></i>
                            <input type="password" id="password" name="password" class="form-control-compact" placeholder="Password" required />
                        </div>
                    </div>

                    <button type="submit" class="btn-auth-compact w-100 mb-2">Login</button>

                    <div class="text-center mb-2 position-relative d-flex align-items-center justify-content-center">
                        <hr class="w-100 opacity-10">
                        <span class="position-absolute bg-auth-compact px-2 text-muted" style="font-size: 0.7rem; font-weight: bold;">OR</span>
                    </div>

                    <div class="mb-3">
                        <a href="/auth/facebook" class="btn-facebook-compact w-100">
                            <i class="fab fa-facebook-f me-2"></i> Continue with Facebook
                        </a>
                    </div>

                    <div class="text-center border-top pt-3 mt-3">
                        <p class="small mb-0 text-muted">Don't have an account? <a href="/goToSignUpPage" class="auth-link fw-bold">Sign up</a></p>
                    </div>
                </form>
            </div>
        </div>

    </body>
</html>
